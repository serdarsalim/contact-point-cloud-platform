# Prisma / Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Session auth
AUTH_SESSION_SECRET="replace-with-long-random-secret"

# API token hashing
TOKEN_HASH_SALT="replace-with-long-random-salt"

# Optional app base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional seed defaults
# Superadmin is a global user (not an org member). The org values below are only for optional bootstrap org creation.
SEED_SUPERADMIN_ORG_NAME="Contact Point HQ"
SEED_SUPERADMIN_ORG_SLUG="contact-point-hq"
SEED_SUPERADMIN_USERNAME="superadmin"
SEED_SUPERADMIN_EMAIL="superadmin@example.com"
SEED_SUPERADMIN_PASSWORD=""
