generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  SUPERADMIN
  ADMIN
}

enum TemplateType {
  EMAIL
  WHATSAPP
  NOTE
}

model User {
  id             String               @id @default(cuid())
  username       String               @unique
  email          String               @unique
  passwordHash   String
  memberships    OrganizationMember[]
  createdApiKeys OrganizationApiKey[] @relation("ApiKeyCreator")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model Organization {
  id        String               @id @default(cuid())
  name      String               @unique
  slug      String               @unique
  members   OrganizationMember[]
  apiKeys   OrganizationApiKey[]
  templates Template[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model OrganizationMember {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, role])
}

model OrganizationApiKey {
  id             String   @id @default(cuid())
  organizationId String
  createdByUserId String?
  label          String
  prefix         String
  tokenHash      String   @unique
  scopes         String[] @default(["templates:read"])
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User?       @relation("ApiKeyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, revokedAt])
  @@index([prefix])
}

model Template {
  id             String       @id @default(cuid())
  organizationId String
  type           TemplateType
  name           String
  subject        String?
  body           String
  imageAssetId   String?
  imageAlt       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@unique([organizationId, type, name])
}
